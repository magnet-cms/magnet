{
  "$schema": "https://v2-8-17.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "ANALYZE",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "CACHE_REDIS_URL",
    "CLERK_JWT_KEY",
    "CLERK_SECRET_KEY",
    "CLOUDFLARE_ACCOUNT_ID",
    "DATABASE_URL",
    "EMAIL_FROM",
    "JWT_SECRET",
    "LOG_FORMAT",
    "LOG_LEVEL",
    "LOG_STACK_TRACES",
    "LOG_TIMESTAMPS",
    "MAGNET_ADMIN_PATH",
    "MAGNET_E2E_DISABLE_AUTH_THROTTLE",
    "MAGNET_PLAYGROUND_MODULES_PATH",
    "MAILPIT_URL",
    "MONGODB_URI",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_GOOGLE_PLACES_API_KEY",
    "NODE_ENV",
    "POLAR_ACCESS_TOKEN",
    "POLAR_ORGANIZATION_ID",
    "POLAR_WEBHOOK_SECRET",
    "PORT",
    "R2_ACCESS_KEY_ID",
    "R2_ACCOUNT_ID",
    "R2_BUCKET",
    "R2_PUBLIC_URL",
    "R2_SECRET_ACCESS_KEY",
    "REDIS_URL",
    "RESEND_API_KEY",
    "S3_ACCESS_KEY_ID",
    "S3_BUCKET",
    "S3_ENDPOINT",
    "S3_PUBLIC_URL",
    "S3_REGION",
    "S3_SECRET_ACCESS_KEY",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_DSN",
    "SENTRY_ENVIRONMENT",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_RELEASE",
    "SENTRY_URL",
    "SMTP_HOST",
    "SMTP_PASS",
    "SMTP_PORT",
    "SMTP_USER",
    "STRIPE_PUBLISHABLE_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "SUPABASE_JWT_PUBLIC_KEY",
    "SUPABASE_JWT_SECRET",
    "SUPABASE_PUBLISHABLE_KEY",
    "SUPABASE_SECRET_KEY",
    "SUPABASE_STORAGE_BUCKET",
    "SUPABASE_URL",
    "TEMPLATE_NAME",
    "VAULT_ADDR",
    "VAULT_MASTER_KEY",
    "VAULT_ROLE_ID",
    "VAULT_SECRET_ID",
    "VAULT_TOKEN",
    "VITE_BASE_PATH"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "interactive": true,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["API_BASE_URL", "UI_BASE_URL", "DOCS_BASE_URL", "CI"]
    },
    "test:watch": {
      "dependsOn": ["^build"],
      "cache": false,
      "interactive": true,
      "persistent": true
    }
  }
}
