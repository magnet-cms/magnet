{
  "name": "@magnet-cms/core",
  "version": "4.0.0",
  "description": "Core NestJS module for Magnet CMS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./modules": {
      "import": {
        "types": "./dist/modules.d.ts",
        "default": "./dist/modules.js"
      },
      "require": {
        "types": "./dist/modules.d.cts",
        "default": "./dist/modules.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:fix": "eslint . --max-warnings 0 --fix"
  },
  "dependencies": {
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@react-email/components": "1.0.10",
    "@react-email/render": "2.0.4",
    "handlebars": "4.7.8",
    "helmet": "^8.0.0",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "@magnet-cms/admin": "workspace:*",
    "@magnet-cms/common": "workspace:*",
    "@magnet-cms/utils": "workspace:*",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.1.12",
    "@nestjs/core": "^11.1.12",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.12",
    "@repo/tsup": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest": "workspace:*",
    "@vitest/coverage-v8": "^3.1.1",
    "reflect-metadata": "0.2.2",
    "vitest": "^3.1.1",
    "@types/express": "^5.0.0",
    "@types/sanitize-html": "^2.13.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/ms": "2.1.0",
    "@types/multer": "^1.4.12",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/passport": "^1.0.16",
    "@types/passport-facebook": "3.0.4",
    "@types/passport-github2": "1.2.9",
    "@types/passport-google-oauth20": "2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^5.0.0",
    "http-proxy-middleware": "^3.0.3",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "ms": "^2.1.3",
    "passport": "^0.7.0",
    "passport-discord": "0.1.4",
    "passport-facebook": "3.0.0",
    "passport-github2": "0.1.12",
    "passport-google-oauth20": "2.0.0",
    "passport-jwt": "^4.0.1",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "@repo/eslint-config": "workspace:*"
  },
  "peerDependencies": {
    "@magnet-cms/common": "^0.4.0",
    "@magnet-cms/utils": "^0.1.1",
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-express": "^11.1.12",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "sharp": "^0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  }
}
