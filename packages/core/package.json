{
  "name": "@magnet-cms/core",
  "version": "1.0.3",
  "description": "Core NestJS module for Magnet CMS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./modules": {
      "import": {
        "types": "./dist/modules.d.ts",
        "default": "./dist/modules.js"
      },
      "require": {
        "types": "./dist/modules.d.cts",
        "default": "./dist/modules.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:dev": "tsup --watch",
    "build": "tsup && cp -r src/modules/email/templates dist/templates",
    "lint": "biome check src",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/terminus": "^11.0.0",
    "handlebars": "4.7.8"
  },
  "devDependencies": {
    "@magnet-cms/admin": "workspace:*",
    "@magnet-cms/common": "workspace:*",
    "@magnet-cms/utils": "workspace:*",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.1.12",
    "@nestjs/core": "^11.1.12",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.12",
    "@repo/biome": "workspace:*",
    "@repo/tsup": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/multer": "^1.4.12",
    "@types/passport-facebook": "3.0.4",
    "@types/passport-github2": "1.2.9",
    "@types/passport-google-oauth20": "2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "http-proxy-middleware": "^3.0.3",
    "passport-discord": "0.1.4",
    "passport-facebook": "3.0.0",
    "passport-github2": "0.1.12",
    "passport-google-oauth20": "2.0.0",
    "passport-jwt": "^4.0.1",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5"
  },
  "peerDependencies": {
    "@magnet-cms/common": "^0.1.0",
    "@magnet-cms/utils": "^0.1.0",
    "@nestjs/common": "^11.1.12",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.12",
    "@nestjs/platform-express": "^11.1.12",
    "sharp": "^0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  }
}