<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { margin: 0; padding: 0; background-color: #f4f4f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    .container { max-width: 560px; margin: 0 auto; padding: 40px 20px; }
    .card { background: #ffffff; border-radius: 8px; padding: 32px; border: 1px solid #e4e4e7; }
    .footer { text-align: center; padding: 24px 0 0; color: #71717a; font-size: 12px; }
    .footer a { color: #71717a; text-decoration: underline; }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      {{{content}}}
    </div>
    <div class="footer">
      <p>This email was sent by your application.</p>
      {{#if appUrl}}<p><a href="{{appUrl}}">{{appUrl}}</a></p>{{/if}}
    </div>
  </div>
</body>
</html>
