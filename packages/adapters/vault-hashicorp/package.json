{
  "name": "@magnet-cms/adapter-vault-hashicorp",
  "version": "4.0.0",
  "description": "HashiCorp Vault adapter for Magnet CMS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:dev": "tsup --watch",
    "build": "tsup",
    "lint:fix": "eslint . --max-warnings 0 --fix"
  },
  "devDependencies": {
    "@magnet-cms/common": "workspace:*",
    "@repo/tsup": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "node-vault-client": "^1.0.0",
    "@repo/eslint-config": "workspace:*"
  },
  "peerDependencies": {
    "@magnet-cms/common": "^0.4.0",
    "node-vault-client": "^1.0.0"
  }
}
