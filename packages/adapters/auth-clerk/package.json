    "@repo/tsup": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "passport": "^0.7.0",
    "passport-custom": "1.1.1"
  },
  "peerDependencies": {
    "@clerk/backend": "^3.0.0",
    "@magnet-cms/common": "^0.1.0",
