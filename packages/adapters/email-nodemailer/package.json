{
  "name": "@magnet-cms/email-nodemailer",
  "version": "3.0.0",
  "description": "Nodemailer email adapter for Magnet CMS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@magnet-cms/common": "workspace:*",
    "@repo/biome": "workspace:*",
    "@repo/tsup": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest": "workspace:*",
    "@vitest/coverage-v8": "^3.1.1",
    "reflect-metadata": "0.2.2",
    "vitest": "^3.1.1",
    "nodemailer": "^6.9.0",
    "@types/nodemailer": "^6.4.0"
  },
  "peerDependencies": {
    "@magnet-cms/common": "^0.4.0",
    "nodemailer": "^6.9.0"
  }
}
