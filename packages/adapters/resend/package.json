{
  "name": "@magnet-cms/adapter-resend",
  "version": "0.1.0",
  "description": "Resend email adapter for Magnet CMS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:dev": "tsup --watch",
    "build": "tsup"
  },
  "devDependencies": {
    "@magnet-cms/common": "workspace:*",
    "@repo/biome": "workspace:*",
    "@repo/tsup": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "resend": "^4.0.0"
  },
  "peerDependencies": {
    "@magnet-cms/common": "^0.1.0",
    "resend": "^4.0.0"
  }
}
