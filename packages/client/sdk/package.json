{
  "name": "@magnet-cms/client",
  "version": "0.1.0",
  "description": "Type-safe client SDK for Magnet CMS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "magnet-client": "./bin/magnet-client.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build:dev": "tsup --watch",
    "build": "tsup",
    "lint": "biome check src",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "14.0.3",
    "openapi-fetch": "0.17.0",
    "openapi-typescript": "7.13.0"
  },
  "devDependencies": {
    "@repo/biome": "workspace:*",
    "@repo/tsup": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest": "workspace:*",
    "@vitest/coverage-v8": "^3.1.1",
    "vitest": "^3.1.1"
  }
}
