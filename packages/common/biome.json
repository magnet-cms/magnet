{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"extends": ["@repo/biome/base"],
	"overrides": [
		{
			"include": [
				"**/__tests__/**",
				"**/*.spec.ts",
				"**/*.spec.tsx",
				"**/*.test.ts",
				"**/*.test.tsx"
			],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		}
	]
}
