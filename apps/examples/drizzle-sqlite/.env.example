# SQLite (file-based, no Docker needed for DB)
DATABASE_URL=./sqlite.db

# JWT secret for authentication
JWT_SECRET=development-secret-key

# S3 Storage (MinIO via Docker)
S3_BUCKET=magnet-media
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000

# Email (MailPit SMTP via Docker)
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=noreply@magnet.local

# Vault (built-in DB adapter)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_MASTER_KEY=your-64-char-hex-key-here

# Server port
PORT=3000

# Environment
NODE_ENV=development
