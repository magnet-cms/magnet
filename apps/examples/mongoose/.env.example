# MongoDB
MONGODB_URI=mongodb://localhost:27017/cats-example

# JWT
JWT_SECRET=development-secret-key

# Vault (optional — enables secrets management via HashiCorp Vault)
# Start the dev Vault server: docker compose -f docker/docker-compose.yml up -d
# Secrets are auto-seeded by the vault-init service
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=dev-token
